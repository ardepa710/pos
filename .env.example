# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pos_user:pos_password@db:5432/pos_db
DATABASE_SYNC_URL=postgresql://pos_user:pos_password@db:5432/pos_db

# ── Seguridad ──────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Banxico (tipo de cambio USD) ───────────────────────────────
BANXICO_API_KEY=your_banxico_api_key_here

# ── Licenciamiento ─────────────────────────────────────────────
# Modos: none | offline_key | online_activation
LICENSE_MODE=none
LICENSE_PUBLIC_KEY=
LICENSE_ACTIVATION_SERVER=

# ── Modo demo ─────────────────────────────────────────────────
DEMO_MODE=false

# ── Negocio ───────────────────────────────────────────────────
BUSINESS_NAME=Mi Negocio
BUSINESS_TYPE=general

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Backups ───────────────────────────────────────────────────
BACKUP_PATH=/backups
DRIVE_BACKUP_ENABLED=false
DRIVE_CREDENTIALS_PATH=

# ── Print Bridge ──────────────────────────────────────────────
PRINT_BRIDGE_URL=http://localhost:9100
PRINT_BRIDGE_ENABLED=false

# ── Telemetría (opt-in) ────────────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=

# ── WhatsApp soporte ──────────────────────────────────────────
SUPPORT_WHATSAPP=

# ── Entorno ───────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
