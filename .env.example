# ── Base de datos ──────────────────────────────────────────────
# These two are used by docker-compose.yml to set DB credentials
DB_PASSWORD=pos_password
JWT_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING

# These are injected into the backend container
DATABASE_URL=postgresql+asyncpg://pos_user:pos_password@pos-db:5432/pos_db?sslmode=disable
DATABASE_SYNC_URL=postgresql://pos_user:pos_password@pos-db:5432/pos_db?sslmode=disable
# Note: sslmode=disable is intentional — internal Docker bridge network only.
#       Never expose this database port externally.

# ── Seguridad ──────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Banxico (tipo de cambio USD) ───────────────────────────────
# Obtén tu clave en: https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_API_KEY=

# ── Licenciamiento ─────────────────────────────────────────────
# Modos: none | offline_key | online_activation
LICENSE_MODE=none
LICENSE_PUBLIC_KEY=
LICENSE_ACTIVATION_SERVER=

# ── Modo demo ─────────────────────────────────────────────────
DEMO_MODE=false

# ── Negocio ───────────────────────────────────────────────────
BUSINESS_NAME=Mi Negocio
BUSINESS_TYPE=general

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80

# ── Backups ───────────────────────────────────────────────────
BACKUP_PATH=/backups

# ── Print Bridge ──────────────────────────────────────────────
# El Print Bridge corre en el HOST (no en Docker) en el puerto 9100.
# IMPORTANTE: usar host.docker.internal (no localhost) — desde dentro de
# Docker, localhost apunta al contenedor, no al host Windows.
PRINT_BRIDGE_URL=http://host.docker.internal:9100
PRINT_BRIDGE_ENABLED=false

# ── Telemetría (opt-in) ────────────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=

# ── WhatsApp soporte ──────────────────────────────────────────
SUPPORT_WHATSAPP=

# ── Entorno ───────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO

# ── Contraseña inicial admin (generada por install script) ────
# ADMIN_INITIAL_PASSWORD=  ← el script de instalación la agrega aquí
