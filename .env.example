# ═══════════════════════════════════════════════════════════════
# POS — Environment variables
#
# Quick start:
#   cp .env.example .env
#   nano .env          ← fill in the REQUIRED values
#   docker compose -f docker-compose.prod.yml up -d
#
# REQUIRED = must change before running
# OPTIONAL = has a safe default, change only if needed
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────────────

# Password for the internal PostgreSQL database.
# Any characters are safe — the backend URL-encodes it automatically.
DB_PASSWORD=CHANGE_ME_strong_db_password

# Database connection URLs — constructed from DB_PASSWORD above.
# If DB_PASSWORD has no special characters, copy these exactly (just replace CHANGE_ME_strong_db_password).
# If DB_PASSWORD has special chars, URL-encode them: @ → %40  $ → %24  ! → %21  # → %23
DATABASE_URL=postgresql+asyncpg://pos_user:CHANGE_ME_strong_db_password@pos-db:5432/pos_db
DATABASE_SYNC_URL=postgresql://pos_user:CHANGE_ME_strong_db_password@pos-db:5432/pos_db

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Admin user password. The admin account is created (or updated)
# with this password on every container start.
# Login: username=admin  password=<this value>
ADMIN_INITIAL_PASSWORD=CHANGE_ME_admin_password

# Your business name — shown in the UI header.
BUSINESS_NAME=Mi Negocio

# CORS origins — must include the URL you use to access the app.
# Single domain:  CORS_ORIGINS=["https://pos.tudominio.com"]
# Multi domain:   CORS_ORIGINS=["https://pos.tudominio.com","http://localhost:3005"]
CORS_ORIGINS=["http://localhost:3005"]

# ── OPTIONAL ────────────────────────────────────────────────────

# Port the app is exposed on (default: 3005)
PORT=3005

# Docker image tag to pull. Options:
#   latest  — most recent build from main branch (default)
#   stable  — last version manually marked as stable
#   abc1234 — specific git commit SHA (for pinning or rollback)
TAG=latest

# Session timeout in minutes (default: 480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Business type — used for UI hints. Options: general | restaurant | retail
BUSINESS_TYPE=general

# Banxico exchange rate API key (for USD/MXN conversion).
# Get yours at: https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_API_KEY=

# Print Bridge — thermal printer support.
# The Print Bridge app runs on the HOST machine on port 9100.
# Leave PRINT_BRIDGE_ENABLED=false if you don't use a thermal printer.
PRINT_BRIDGE_URL=http://host.docker.internal:9100
PRINT_BRIDGE_ENABLED=false

# WhatsApp support link (shown in the UI). Format: 521XXXXXXXXXX
SUPPORT_WHATSAPP=

# Demo mode — disables all write operations (read-only UI).
DEMO_MODE=false

# Licensing (leave as-is for self-hosted).
LICENSE_MODE=none
LICENSE_PUBLIC_KEY=
LICENSE_ACTIVATION_SERVER=

# Telemetry (opt-in, disabled by default).
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
